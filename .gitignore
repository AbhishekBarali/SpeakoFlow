tauri.local-build.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

.claude/
CLAUDE.md

/target/
recording_*
.crush/

# Local cargo config (per-machine build/linker settings; not needed to build the app)
.cargo/

.direnv
.envrc

# Nix build output
result

# Knowledge-graph analysis output: internal AI-tooling artifact, kept out of
# the public repo entirely (regenerable from source).
graphify-out/

# Editor / agent tooling
.kiro/
.agents/
.impeccable/

# Firecrawl MCP diagnostic scratch files (may contain API keys)
.fc_*

# Secrets / credentials — never commit real keys. The app already stores keys
# in the OS keychain (secret_store.rs) and its working settings live under the
# OS app-data dir, so none of this is normally in-tree; these rules are a guard
# against accidental drops.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore
credentials.json
secrets.json
# Local Tauri app settings store (holds provider API keys when configured).
settings_store.json

# Internal marketing/testing website — kept out of the app repo
speakoflow-website/

# Internal generated docs/reference HTML (local-only, regenerable)
speakoflow-docs.html
speakoflow-feature-reference.html

# Internal launch & competitive-strategy playbook — kept out of the public repo
# (self-declared internal; contains launch tactics + competitor analysis).
LAUNCH_PLAN.md

# Demo / marketing capture tooling (not shipped, regenerable, dev-only).
# The capture harness, its config, the demo-only entry points, and the
# generated screenshots are all kept out of the public repo.
demo-assets/
demo-capture/
src/assistant/panel-demo.html
src/assistant/panel-demo.tsx
src/overlay/preview.html
src/overlay/preview.tsx
